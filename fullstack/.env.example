# Configuración de Correo Electrónico
# Copia este archivo como .env y completa con tus credenciales

# Gmail Configuration (Recomendado para desarrollo)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false

# Tus credenciales de Gmail
# IMPORTANTE: Para Gmail, debes generar una "Contraseña de aplicación"
# Ve a: https://myaccount.google.com/apppasswords
MAIL_USERNAME=tu-correo@gmail.com
MAIL_PASSWORD=tu-contraseña-de-aplicacion

# Remitente por defecto
MAIL_DEFAULT_SENDER=noreply@erpeducativo.com

# Secret Key (Cambiar en producción)
SECRET_KEY=tu-clave-secreta-super-segura-cambiar-en-produccion

# ========================================
# Instrucciones para configurar Gmail:
# ========================================
# 1. Ve a tu cuenta de Google
# 2. Activa la verificación en 2 pasos
# 3. Ve a "Contraseñas de aplicaciones"
# 4. Genera una nueva contraseña para "Correo"
# 5. Usa esa contraseña en MAIL_PASSWORD
#
# Más info: https://support.google.com/accounts/answer/185833
# ========================================

# Otras opciones de servidor de correo:

# Outlook/Hotmail
# MAIL_SERVER=smtp.office365.com
# MAIL_PORT=587

# Yahoo
# MAIL_SERVER=smtp.mail.yahoo.com
# MAIL_PORT=587

# SendGrid (Servicio profesional)
# MAIL_SERVER=smtp.sendgrid.net
# MAIL_PORT=587
